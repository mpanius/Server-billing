APP_NAME=Server Billing Manager
DATABASE_PATH=./data/server_billing.db
BASE_URL=http://127.0.0.1:8000
SERVER_IP=127.0.0.1
CADDY_SITE_ADDRESS=127.0.0.1.sslip.io
CADDY_EMAIL=
# Ключи приложения — в файлах (рекомендуется), не в .env:
APP_SECRET_KEY_FILE=secrets/session.key
APP_ENCRYPTION_KEY_WRAP_FILE=secrets/encryption.key.wrap
PANEL_KEY_PASSPHRASE_FILE=secrets/unlock.passphrase
# Legacy (до wrap): APP_ENCRYPTION_KEY_FILE=secrets/encryption.key
# Legacy (не рекомендуется): APP_SECRET_KEY= / APP_ENCRYPTION_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
REMINDER_DAYS=7,3,1,0,-1
CHECK_INTERVAL_SECONDS=86400
BACKUP_INTERVAL_DAYS=7
CURRENCY_BASE=RUB
CURRENCY_RATES=RUB:1
CURRENCY_RATES_UPDATED_AT=
APP_UPDATE_URL=http://updater:8765/update
# Минимум 32 символа; тот же токен передаётся в контейнер updater как UPDATER_TOKEN
APP_UPDATE_TOKEN=
PROVIDER_CATALOG_URL=
# IP allowlist (пусто = без ограничений). TRUSTED_PROXIES — IP/CIDR reverse proxy (для Docker укажите IP контейнера Caddy/nginx):
PANEL_IP_ALLOWLIST=
TRUSTED_PROXIES=
