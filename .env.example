APP_NAME=Server Billing Manager
DATABASE_PATH=./data/server_billing.db
BASE_URL=http://127.0.0.1:8000
SERVER_IP=127.0.0.1
CADDY_SITE_ADDRESS=127.0.0.1.sslip.io
CADDY_EMAIL=
# Обязательны для доступа к панели (иначе вход заблокирован):
APP_SECRET_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
# Обязателен для сохранения паролей/API-ключей и Telegram-бэкапов:
APP_ENCRYPTION_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
REMINDER_DAYS=7,3,1,0,-1
CHECK_INTERVAL_SECONDS=86400
BACKUP_INTERVAL_DAYS=7
CURRENCY_BASE=RUB
CURRENCY_RATES=RUB:1
CURRENCY_RATES_UPDATED_AT=
APP_UPDATE_URL=
# Минимум 32 символа; updater отклоняет более короткие токены
APP_UPDATE_TOKEN=
PROVIDER_CATALOG_URL=
# IP allowlist (пусто = без ограничений). TRUSTED_PROXIES — IP/CIDR reverse proxy (для Docker укажите IP контейнера Caddy/nginx):
PANEL_IP_ALLOWLIST=
TRUSTED_PROXIES=
